<Window x:Class="PixelPainterCSharp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="PixelPainter C#" Height="600" Width="900"
        Background="#1E1E1E" Foreground="White"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="250" />
        </Grid.ColumnDefinitions>

        <!-- Left Controls -->
        <StackPanel Grid.Column="0" Margin="0,0,15,0">
            <TextBlock Text="PixelPainter" FontSize="26" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <ui:Button Content="Load Image" Click="LoadImage_Click" HorizontalAlignment="Stretch" Margin="0,0,0,10" Appearance="Primary" />
            <TextBlock x:Name="TxtFilePath" Text="No file selected" TextTrimming="CharacterEllipsis" Margin="0,0,0,20" Foreground="Gray"/>
            
            <TextBlock Text="Max Colors" Margin="0,0,0,5"/>
            <Slider x:Name="SldColors" Minimum="2" Maximum="24" Value="8" IsSnapToTickEnabled="True" TickFrequency="1" ValueChanged="Settings_Changed" Margin="0,0,0,5"/>
            <TextBlock x:Name="TxtColorsCount" Text="8" Margin="0,0,0,20" Foreground="Gray"/>

            <TextBlock Text="Delay between clicks (ms)" Margin="0,0,0,5"/>
            <ui:TextBox x:Name="TxtDelay" Text="3" Margin="0,0,0,20" />

            <TextBlock Text="Drawing Area" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <ui:Button Content="Set Top-Left" Click="SetTopLeft_Click" HorizontalAlignment="Stretch" Margin="0,0,0,5" />
            <TextBlock x:Name="TxtTopLeft" Text="X: 0, Y: 0" Margin="0,0,0,10" Foreground="Gray"/>
            
            <ui:Button Content="Set Bottom-Right" Click="SetBottomRight_Click" HorizontalAlignment="Stretch" Margin="0,0,0,5" />
            <TextBlock x:Name="TxtBottomRight" Text="X: 0, Y: 0" Margin="0,0,0,20" Foreground="Gray"/>

            <ui:Button Content="START PAINTING" Click="StartPainting_Click" HorizontalAlignment="Stretch" Appearance="Success" Height="40" FontSize="16" />
            <TextBlock Text="Press ESC to stop" Margin="0,5,0,0" Foreground="IndianRed" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Center Preview -->
        <Border Grid.Column="1" BorderBrush="#333" BorderThickness="1" Background="#121212" Margin="0,0,15,0" CornerRadius="8">
            <Grid>
                <TextBlock Text="Preview will appear here" Foreground="#555" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Image x:Name="ImgPreview" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor" Margin="5" />
            </Grid>
        </Border>

        <!-- Right Palette -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Palette Mapping" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="IcPalette">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="{Binding ColorBrush}" Width="30" Height="30" CornerRadius="4" BorderBrush="#444" BorderThickness="1"/>
                                <TextBlock Grid.Column="1" Text="{Binding PosText}" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="LightGray" TextWrapping="Wrap"/>
                                <ui:Button Grid.Column="2" Content="Map" CommandParameter="{Binding}" Click="MapColor_Click" Padding="10,5"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
